{
  "name": "package-return-tracker",
  "displayName": "Package Return Tracker",
  "description": "A VS Code sidebar assistant to track package return windows and surface return reminders.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:packageReturnTracker.sidebarView",
    "onCommand:packageReturnTracker.helloWorld"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "packageReturnTracker.helloWorld",
        "title": "Package Return Tracker: Hello World"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "packageReturnTracker.container",
          "title": "Return Tracker"
        }
      ]
    },
    "views": {
      "packageReturnTracker.container": [
        {
          "id": "packageReturnTracker.sidebarView",
          "name": "Return Dashboard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.5.0",
    "vscode-test": "^2.0.0"
  }
}